# 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 安全密钥（生产环境必须更换）
SECRET_KEY=your-secret-key-here

# 运行端口
PORT=5000

# 调试模式（生产环境设为False）
DEBUG=False

# ── LLM 智能整理（AI 万能整理兜底引擎）默认配置 ──
# 兼容任意 OpenAI 格式接口。配置后，前端不填 API Key 也能触发 LLM 兜底；
# 前端若填写则覆盖这里。留空 LLM_API_KEY 则需前端每次手动填写。
# 示例为 NVIDIA integrate（deepseek-v4-flash）：
LLM_API_KEY=
LLM_API_BASE=https://integrate.api.nvidia.com/v1
LLM_MODEL=deepseek-ai/deepseek-v4-flash
